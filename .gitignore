# Test & coverage
coverage/

# Local debug/verification artifacts
verify-*.js
verify-*.png
verify-*.html
.zcode/
.worktrees/

# Debug previews / scratch files generated during UI work
cyrene-*-preview.html
tmp_*.txt
tmp/
tmpr-build.log
tmprenderer-build.log

# Playwright CLI scratch
.playwright-cli/

# Sim result dumps
sim-result/

# Brainstorming visual companion mockups (local-only artifacts)
.superpowers/

# Windows quirk: 'nul' is a reserved device name, ignore if created by accident
nul

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Sensitive keys and credentials
*.key
*.pem
*.log

# Local env files (keep .env.example tracked)
.env
.env.*
!.env.example
# Video/preview render projects (not source code)
videos/

# Local AI model files (用户下载到 models/，二进制不跟踪 — 见 docs/local-models.md)
# 模型目录约定：
#   - models/Xenova/<repo>/         Embedding 模型（bge-m3 等）
#   - models/<reranker>/            Reranker 模型（bge-reranker-base / ms-marco-MiniLM-L-6-v2）
# 规则说明：
#   - models/Xenova/ 完整目录忽略（用户下载的完整 embedding 模型，含 tokenizer + config + onnx）
#   - 已跟踪的 reranker JSON 元数据保持跟踪（config/tokenizer 等小文件）
#   - 所有 .onnx / onnx_data / .bin / .safetensors 大模型权重永远忽略
models/Xenova/
**/onnx/
**/*.onnx
**/*.onnx_data
**/*.bin
**/*.safetensors

# Local opener voice pack files. Keep the directory and installation note tracked.
opener-pack/*
!opener-pack/.gitkeep
!opener-pack/README.md

# Playwright MCP 运行时产物
.playwright-mcp/

# Private design docs — not published
docs/
!docs/
!docs/local-models.md
!docs/opener-pack.md
!docs/electron-33-to-43-upgrade-assessment.md
PRODUCT.md
sticker-descriptions/
